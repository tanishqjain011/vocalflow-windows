{
  "name": "vocalflow-windows",
  "version": "1.0.0",
  "description": "VocalFlow for Windows — Hold-to-dictate anywhere using Deepgram STT + Groq LLM",
  "main": "main.js",
  "author": "Tanishq",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w uiohook-napi",
    "build": "electron-builder --win",
    "postinstall": "electron-rebuild -f -w uiohook-napi"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-fetch": "^2.7.0",
    "uiohook-napi": "^1.5.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "ai.vocallabs.vocalflow",
    "productName": "VocalFlow",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      "assets/"
    ]
  }
}
